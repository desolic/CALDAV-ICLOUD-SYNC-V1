# =====================================================================
# CALDAV-ICLOUD-SYNC-V1  -  Beispiel-Umgebungsvariablen
# =====================================================================
# In der Synology Container-Manager-GUI unter "Umgebung" eintragen.
# Fuer jedes Geheimnis kann statt VAR alternativ VAR_FILE gesetzt werden
# (Pfad auf eine Datei / Docker-Secret) -> empfohlen statt Klartext.

# ---- iCloud (Pflicht) -----------------------------------------------
# App-spezifisches Passwort unter https://account.apple.com erzeugen,
# NICHT das normale Apple-ID-Passwort verwenden.
APPLE_ID=deine-apple-id@example.com
APPLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Alternativ (empfohlen, via Docker-Secret):
# APPLE_APP_PASSWORD_FILE=/run/secrets/apple_app_password

# ---- Synology (Pflicht) ---------------------------------------------
# URL MUSS mit https:// beginnen.
SYNOLOGY_CALDAV_URL=https://deine-synology:5001/caldav/
SYNOLOGY_USER=synology-user
SYNOLOGY_PASSWORD=synology-passwort
# SYNOLOGY_PASSWORD_FILE=/run/secrets/synology_password

# TLS-Zertifikatspruefung. Nur fuer vertrauenswuerdige LAN-Verbindungen
# mit self-signed Zertifikat auf "false" setzen.
SYNOLOGY_VERIFY=true

# ---- Kalenderauswahl ------------------------------------------------
# auto    : alle gleichnamigen Kalender werden automatisch gepaart (kein weiterer Eintrag noetig)
# named   : nur die in COLLECTIONS genannten (gleicher Name beidseitig)
# mapping : explizite Zuordnung bei unterschiedlichen Namen/IDs
COLLECTIONS_MODE=auto
# COLLECTIONS=Familie,Arbeit
# COLLECTION_MAPPING=[["familie","ICLOUD_ID","SYNOLOGY_ID"]]

# ---- Verhalten (optional) -------------------------------------------
CONFLICT_RESOLUTION=a wins   # "a wins" = iCloud gewinnt, "b wins" = Synology gewinnt
SYNC_INTERVAL=300            # Sekunden zwischen den Syncs
LOG_MAX_BYTES=5242880        # Log-Rotation ab dieser Groesse (5 MiB)
LOG_KEEP=3                   # Anzahl rotierter Logdateien

# ---- Berechtigungen (Synology-Bind-Mounts) --------------------------
# Auf die UID/GID des Besitzers des gemounteten /config-Ordners setzen.
PUID=10001
PGID=10001
